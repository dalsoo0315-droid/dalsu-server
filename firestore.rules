rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - role: string (required, customer|technician|admin|b2b)
    //   - phone: string (required)
    //   - name: string (required)
    //   - location: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: requests
    // Document ID: {requestId}
    // Fields:
    //   - userId: string (required)
    //   - category: string (required)
    //   - location: string (required)
    //   - urgency: string (required)
    //   - status: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dalsoo0315@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'phone', 'name', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.role in ['customer', 'technician', 'admin', 'b2b'] &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['userId', 'category', 'location', 'urgency', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.category is string && data.category.size() > 0 &&
             data.location is string && data.location.size() > 0 &&
             data.status in ['PENDING', 'QUOTED', 'ASSIGNED', 'IN_PROGRESS', 'COMPLETED', 'CANCELLED'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidRequest(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidRequest(request.resource.data);
    }

    match /diagnosis/{diagnosisId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
